{
  "compilerOptions": {
    "target": "esnext", // Soporte moderno para las características de JS/TS.
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ], // Incluye las bibliotecas necesarias.
    "allowJs": true, // Permite usar archivos JS.
    "skipLibCheck": true, // Omite chequeos de tipado en dependencias.
    "strict": true, // Mantiene las comprobaciones estrictas.
    "forceConsistentCasingInFileNames": true, // Asegura consistencia en el caso de nombres de archivos.
    "noEmit": true, // Evita generar archivos JS.
    "esModuleInterop": true, // Garantiza compatibilidad con módulos ES.
    "module": "esnext", // Usa el formato de módulo ES más reciente.
    "moduleResolution": "node", // Configuración estándar para resolver módulos.
    "resolveJsonModule": true, // Permite importar JSON.
    "isolatedModules": true, // Requerido para Next.js.
    "jsx": "preserve", // Para compatibilidad con JSX en Next.js.
    "incremental": true, // Mejora los tiempos de recompilación.
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "src/**/*",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
